<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:entities="clr-namespace:EmmaServer.Entities;assembly=EmmaServer.Entities"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="EmmaClientAv.Forms.Articoli.ArticoliForm"
        x:DataType="entities:EmmaArticoli"
        Opened="Window_OnOpened"
        Closing="ArticoliForm_Closing"
        Title="ArticoliForm">
<Grid RowDefinitions="Auto, *">
        
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10">
        <Button Content="Aggiungi Articolo" Click="Aggiungi_Click" Background="#2ecc71" Foreground="White"/>
        <Button Content="Elimina Selezionato" Click="Elimina_Click" Background="#e74c3c" Foreground="White"/>
        <Button Content="Salva Modifiche" Click="Salva_Click" Background="#3498db" Foreground="White"/>
        
        <Border Width="1" Height="25" Background="#E0E0E0"/>
        
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Label Content="Fornitore:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#333333"/>
            <ComboBox Name="CbFornitore"   x:DataType="entities:EmmaFornitori" 
                      Width="400" 
                      DisplayMemberBinding="{Binding descrizione}"
                      PlaceholderText="Seleziona Fornitore..."/>
        </StackPanel>
        
    </StackPanel>
<DataGrid Grid.Row="1" 
          Name="ArticoliGrid"
          x:DataType="entities:EmmaArticoli" 
          AutoGenerateColumns="False"
          CanUserResizeColumns="True"
          CanUserSortColumns="True"
          GridLinesVisibility="All"
          BorderThickness="1" 
          BorderBrush="Gray"
          Margin="10">
    
    <DataGrid.Columns>
        <DataGridTextColumn Header="ID" 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding id}" 
                            IsReadOnly="True" 
                            Width="60"/>
        
        <DataGridTextColumn Header="Codice" 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding codice, Mode=TwoWay}" 
                            Width="2*"/>
        
        <DataGridTextColumn Header="Descrizione" 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding descrizione, Mode=TwoWay}" 
                            Width="2*"/>
        
        <DataGridTextColumn Header="Riferimento Cod." 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding rifcodice, Mode=TwoWay}" 
                            Width="1.5*"/>
        

        <DataGridTextColumn Header="Riferimento Des." 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding rifdescrizione, Mode=TwoWay}" 
                            Width="1.5*"/>
        
        <DataGridTextColumn Header="Scor Cod." 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding scorecodice, Mode=OneWay}" 
                            IsReadOnly="True" 
                            Width="80"/>
        
        <DataGridTextColumn Header="Score Des." 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding scoredescrizione, Mode=OneWay}" 
                            IsReadOnly="True" 
                            Width="80"/>

        
        <DataGridTextColumn Header="Tenant" 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding tenant, Mode=OneWay}" 
                            IsReadOnly="True" 
                            IsVisible="False"
                            Width="1*"/>

        <DataGridTextColumn Header="Data Creazione" 
                            x:DataType="entities:EmmaArticoli"
                            Binding="{Binding data_creazione, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" 
                            IsReadOnly="True" 
                            Width="150"/>
    </DataGrid.Columns>
</DataGrid>
    </Grid>
</Window>
