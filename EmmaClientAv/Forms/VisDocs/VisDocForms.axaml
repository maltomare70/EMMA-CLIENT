<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:entities="clr-namespace:EmmaServer.Entities;assembly=EmmaServer.Entities"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="EmmaClientAv.Forms.VisDocs.VisDocForms"
        Opened="Window_OnOpened"
        x:Name="RootWindow"
        Title="Visualizzatore Documenti">

    <Grid RowDefinitions="Auto, *" Margin="15">
         
        <Border Grid.Row="0"
                Background="#F9F9F9"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,15">
    
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    


                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Label Content="Tipo Documento:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#333333"/>
                        <ComboBox Name="CbTipoDocumento" 
                                  Width="200" 
                                  PlaceholderText="Seleziona Tipo..."/>
                    </StackPanel>
                    
                    <Border Width="1" Height="25" Background="#E0E0E0"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Label Content="Fornitore:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#333333"/>
                        <ComboBox Name="CbFornitore"   x:DataType="entities:EmmaFornitori"
                                  Width="400" 
                                  DisplayMemberBinding="{Binding descrizione}"
                                  PlaceholderText="Seleziona Fornitore..."/>
                    </StackPanel>
                    
                    <Border Width="1" Height="25" Background="#E0E0E0"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Label Content="Stato Documento:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#333333"/>
                        <ComboBox Name="CbStatoDocumento" 
                                  Width="200" 
                                  PlaceholderText="Seleziona Stato..."/>
                    </StackPanel>
                    
                    <Border Width="1" Height="25" Background="#E0E0E0"/>
                    
                    <Button Click="Button_OnClick"
                            Background="#2196F3"
                            Foreground="White"
                            Padding="15,8"
                            FontWeight="SemiBold"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📁" VerticalAlignment="Center"/>
                            <TextBlock Text="Mostra Documenti ..." VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                  
                    
                </StackPanel>
            </Grid>
        </Border>
        
        <DataGrid Grid.Row="1" 
                  RowDetailsVisibilityMode="VisibleWhenSelected" 
                  Name="DataGridArticoli"
                  x:DataType="entities:MasterDocumento"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  BorderThickness="1"
                  BorderBrush="#D0D0D0"
                 >

            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fornitore" FontWeight="Bold" Binding="{Binding Fornitore}" Width="*"/>
                <DataGridTextColumn Header="Tipo Documento" FontWeight="Bold" Binding="{Binding TipDocumento}" Width="150" IsVisible="False"/>
                <DataGridTextColumn Header="N° Documento" FontWeight="Bold" Binding="{Binding NumeroDocumento}" Width="150"/>
                <DataGridTextColumn Header="Data Documento" FontWeight="Bold" Binding="{Binding DataDocumento}" Width="150"/>
                <DataGridTextColumn Header="Stato Documento" FontWeight="Bold" Binding="{Binding StatoDocumento}" Width="150" IsVisible="False"/>
                
                <DataGridTemplateColumn Header="" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="entities:MasterDocumento">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="{Binding TestoBottone}"
                                        Background="#2196F3"
                                        Foreground="White"
                                        Padding="10,5"
                                        Margin="0,0,5,0"
                                        Click="Button_OnCambioStato"/> 
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="entities:MasterDocumento">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    
                                <Button Content="Elimina"
                                        Background="#F44336"
                                        Foreground="White"
                                        Padding="10,5"
                                        Click="Button_OnElimina"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate x:DataType="entities:MasterDocumento">
                    <Border Background="#F5F5F5" CornerRadius="4" Padding="15" Margin="5">
                        <StackPanel>
                            <DataGrid 
                                ItemsSource="{Binding Dettagli}"
                                      AutoGenerateColumns="False"
                                      Foreground="Black"
                                      IsReadOnly="False" 
                                      GridLinesVisibility="All"
                                      BorderThickness="1"
                                      BorderBrush="#CCCCCC">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codice" Binding="{Binding CodiceArticolo}" IsReadOnly="False" Width="200"/>
                                    <DataGridTextColumn Header="Descrizione" Binding="{Binding DescrizioneArticolo}" IsReadOnly="False" Width="*"/>
                                                   
                                    <DataGridTemplateColumn Width="100">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="U.M." 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </DataGridTemplateColumn.Header>

                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding UnitaMisura}" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTemplateColumn Header="Q.tà" Width="150" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Qta}" 
                                                           HorizontalAlignment="Right" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <NumericUpDown Value="{Binding Qta}" 
                                                               HorizontalContentAlignment="Right"
                                                               FormatString="0" 
                                                               ShowButtonSpinner="True" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    
                                    <DataGridTemplateColumn Header="Imponibile" Width="150" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Imponibile}" 
                                                           HorizontalAlignment="Right" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <NumericUpDown Value="{Binding Imponibile}" 
                                                               HorizontalContentAlignment="Right"
                                                               FormatString="0" 
                                                               ShowButtonSpinner="True" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    
                           
                                    <DataGridTemplateColumn Width="100">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="IVA" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </DataGridTemplateColumn.Header>

                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IVA}" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    
                                    <DataGridTemplateColumn Header="Totale" Width="150" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Totale}" 
                                                           HorizontalAlignment="Right" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <NumericUpDown Value="{Binding Totale}" 
                                                               HorizontalContentAlignment="Right"
                                                               FormatString="0" 
                                                               ShowButtonSpinner="True" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTemplateColumn Width="100">
                                        <DataTemplate x:DataType="entities:RigheDocumento">
                                            <Button Content="{Binding TestoBottone}" 
                                                    Background="#FF4D4D" 
                                                    Foreground="White"
                                                    Padding="5,2"
                                                    HorizontalAlignment="Center"
                                                    Click="EliminaRiga_Click">
                        
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn>
                                    
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <Button Content="+ Aggiungi Articolo"
                                    Name="BtnAggiungiArticolo"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Tag="additem"
                                    />
                            
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>
    </Grid>
</Window>